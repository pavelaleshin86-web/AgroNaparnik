# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production: set your domain(s), comma-separated
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SQLite path (optional; use persistent disk path on Render)
# SQLITE_DB_NAME=db.sqlite3

# Email notifications for contact form
CONTACT_NOTIFY_EMAIL="nexusagro@yandex.com" <nexusagro@yandex.com>
DEFAULT_FROM_EMAIL=noreply@pps.studio

# SMTP (leave EMAIL_HOST empty for console backend in dev)
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=465
# EMAIL_USE_SSL=1
# EMAIL_HOST_USER=your@email.ru
# EMAIL_HOST_PASSWORD=app-password
